<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
<uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
<uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
<!-- App NE koristi advertising ID (nema ad SDK, Analytics pozivi su
     namjerno odgođeni za Fazu 8/9) — firebase_analytics paket automatski
     ubacuje ovu dozvolu u merged manifest bez obzira na to, pa je
     eksplicitno uklanjamo da "No" odgovor u Play Console Advertising ID
     deklaraciji ostane tačan. -->
<uses-permission android:name="com.google.android.gms.permission.AD_ID"
    tools:node="remove"/>
<!-- Isti razlog kao gore — novije Android 13+ "Privacy Sandbox" AdServices
     dozvole, i njih firebase_analytics automatski ubacuje bez obzira na to
     da li se stvarno koriste. -->
<uses-permission android:name="android.permission.ACCESS_ADSERVICES_AD_ID"
    tools:node="remove"/>
<uses-permission android:name="android.permission.ACCESS_ADSERVICES_ATTRIBUTION"
    tools:node="remove"/>
    <application
        android:label="vagabundo"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <!-- Zvaničan Firebase mehanizam za isključivanje AD_ID prikupljanja
             NA NIVOU SDK-a (ne samo manifest dozvole, koju smo već uklonili
             iznad) — firebase-analytics interno ubacuje
             play-services-ads-identifier biblioteku bez obzira na dozvolu,
             ovaj flag govori SDK-u da je nikad ne koristi. -->
        <meta-data
            android:name="google_analytics_adid_collection_enabled"
            android:value="false" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- Android ekvivalent iOS Universal Links — Faza A "cijev" za
                 https://vagabundo.app/p/{token} share linkove. autoVerify
                 zahtijeva assetlinks.json hostovan na toj domeni (vidi
                 napomenu korisniku), inače link otvara browser umjesto app-a. -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="https"
                    android:host="vagabundo.app"
                    android:pathPrefix="/p" />
            </intent-filter>
            <!-- Flutter podrazumijevano prosljeđuje Intent data URI direktno
                 GoRouter-u kao rutu ("Flutter deep linking"), što je u
                 sukobu sa app_links pristupom (IncomingLinkService) —
                 GoRouter baca "no routes for location" jer /p/{token} nije
                 GoRoute path. Isključeno: app_links i dalje prima Intent
                 nezavisno preko svog native kanala. -->
            <meta-data
                android:name="flutter_deeplinking_enabled"
                android:value="false" />
        </activity>
        <!-- TODO: zamijeni sa stvarnim Google Maps API ključem (Google Cloud
             Console → Maps SDK for Android). Bez validnog ključa GoogleMap
             widget (DayMapView, Faza 4) neće prikazati kartice — to je runtime
             greška, ne build greška. -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${mapsApiKey}" />
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- Package visibility (Android 11+) — bez ovoga canLaunchUrl() za
             market:// vraća false čak i kad je Play Store instaliran, pa
             ReviewManager.openPlayStorePage() uvijek pada na browser fallback. -->
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="market"/>
        </intent>
    </queries>
</manifest>